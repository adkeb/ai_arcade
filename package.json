{
  "name": "ai-arcade",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --filter @ai-arcade/web dev",
    "worker": "pnpm --filter @ai-arcade/worker dev",
    "dev:all": "concurrently -n web,worker -c cyan,magenta \"pnpm dev\" \"pnpm worker\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @ai-arcade/web lint",
    "test:unit": "TMPDIR=/tmp tsx --tsconfig tsconfig.test.json --test tests/unit/*.test.ts",
    "test:integration": "TMPDIR=/tmp tsx --tsconfig tsconfig.test.json --test tests/integration/*.test.ts",
    "test:external": "TMPDIR=/tmp tsx --tsconfig tsconfig.test.json scripts/smoke-external.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:install-deps": "playwright install --with-deps chromium",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:seed": "tsx packages/db/prisma/seed.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ai-arcade/agent": "workspace:*",
    "@ai-arcade/db": "workspace:*",
    "@ai-arcade/shared": "workspace:*",
    "@ai-arcade/storage": "workspace:*",
    "@aws-sdk/client-s3": "^3.930.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.61.0",
    "dotenv": "^17.2.3",
    "ioredis": "5.10.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "prisma": "^6.18.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
