DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ai_arcade
REDIS_URL=redis://redis:6379
SESSION_SECRET=replace-me-with-a-long-random-secret
APP_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Host-local defaults. docker-compose.yml overrides service-to-service S3_ENDPOINT as http://minio:9000.
S3_ENDPOINT=http://localhost:9002
S3_PUBLIC_ENDPOINT=http://localhost:9002
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ASSETS_BUCKET=game-assets
S3_ARTIFACTS_BUCKET=game-artifacts

OPENAI_API_KEY=
OPENAI_BASE_URL=https://llm-fqmv3nbrmalei7ti.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.7-plus
OPENAI_ENABLE_THINKING=true
OPENAI_JSON_RESPONSE_FORMAT=true
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://llm-fqmv3nbrmalei7ti.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-plus
DASHSCOPE_ENABLE_THINKING=true
# Real Create/Regenerate generation requires OPENAI_API_KEY or DASHSCOPE_API_KEY.
# Set USE_LOCAL_AGENT_FALLBACK=true only for offline demo seeds and tests.
USE_LOCAL_AGENT_FALLBACK=false

ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
DOCMIND_ACCESS_KEY_ID=
DOCMIND_ACCESS_KEY_SECRET=
DOCMIND_ENABLED=true
DOCMIND_ENDPOINT=docmind-api.cn-hangzhou.aliyuncs.com
DOCMIND_REGION_ID=cn-hangzhou
DOCMIND_LLM_ENHANCEMENT=true
DOCMIND_ENHANCEMENT_MODE=VLM
DOCMIND_POLL_ATTEMPTS=18
DOCMIND_POLL_INTERVAL_MS=2000
RUN_EXTERNAL_SMOKE=false

MAX_UPLOAD_MB=20
JOB_TIMEOUT_SECONDS=120
